# ================================================================
# OKR System — Variables de entorno
# Copiar a .env y completar todos los valores marcados con CHANGE_ME
# NUNCA commitar el .env real al repositorio
# Generar secrets con: openssl rand -hex 32
# ================================================================

# ── Entorno ────────────────────────────────────────────────────
NODE_ENV=production

# ── Aplicación ─────────────────────────────────────────────────
PORT=3010
FRONTEND_URL=https://CHANGE_ME.com
API_URL=https://CHANGE_ME.com/api
COOKIE_SECRET=CHANGE_ME

# ── Base de datos ───────────────────────────────────────────────
DATABASE_URL=postgresql://okr_user:CHANGE_ME@localhost:5432/okr_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=okr_db
DB_USER=okr_user
DB_PASSWORD=CHANGE_ME

# ── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@localhost:6379
REDIS_PASSWORD=CHANGE_ME

# ── Anthropic (IA) ──────────────────────────────────────────────
# Obtener en: https://console.anthropic.com
ANTHROPIC_API_KEY=CHANGE_ME
AI_DEFAULT_MODEL=claude-sonnet-4-6
AI_HEAVY_MODEL=claude-opus-4-7
AI_FAST_MODEL=claude-haiku-4-5-20251001
AI_MAX_TOKENS=4096
AI_RATE_LIMIT_DAILY=100
MCP_SERVER_PATH=/mcp

# ── Email (SMTP) ────────────────────────────────────────────────
# Requerido para: password reset, invitaciones por email
# Proveedor recomendado: Brevo (brevo.com) — tier gratuito 300 emails/día
#   Host: smtp-relay.brevo.com  Puerto: 587
#   Usuario: tu email de cuenta Brevo
#   Contraseña: clave SMTP de SMTP & API → SMTP en el dashboard
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME@domain.com
SMTP_PASS=CHANGE_ME
SMTP_FROM=no-reply@CHANGE_ME.com

# ── Cron Jobs ──────────────────────────────────────────────────
CRON_RISK_SENTINEL=0 2 * * *
CRON_EXECUTIVE_BRIEFER=0 8 * * 1

# ── Stripe (pasarela de pago) ───────────────────────────────────
# 1. Claves: dashboard.stripe.com → Developers → API keys → sk_live_...
# 2. Productos: Stripe Products → crear "OKR System PRO" con dos precios:
#    - PRO Mensual: USD 49/mes → copiar price_XXXX como STRIPE_PRICE_PRO_MONTHLY
#    - PRO Anual:   USD 490/año → copiar price_XXXX como STRIPE_PRICE_PRO_ANNUAL
# 3. Webhook: Stripe Webhooks → Add endpoint:
#    URL: https://TU_DOMINIO/api/v1/billing/stripe/webhook
#    Eventos a escuchar:
#      checkout.session.completed
#      invoice.payment_succeeded
#      invoice.payment_failed
#      customer.subscription.updated
#      customer.subscription.deleted
#    → copiar el Signing secret como STRIPE_WEBHOOK_SECRET
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_PRO_MONTHLY=price_CHANGE_ME
STRIPE_PRICE_PRO_ANNUAL=price_CHANGE_ME

# ── MercadoPago (opcional — solo si operas en LATAM) ───────────
# Obtener en: https://www.mercadopago.com.ar/developers/es/docs/checkout-api/landing
MP_ACCESS_TOKEN=CHANGE_ME

# ── Sentry (error tracking) ─────────────────────────────────────
# Obtener en: https://sentry.io — crear proyecto Node.js para backend y Next.js para frontend
# Si no se configura, los errores solo quedan en los logs del servidor
SENTRY_DSN=CHANGE_ME
SENTRY_AUTH_TOKEN=CHANGE_ME

# ── Telegram (alertas de agentes IA) ────────────────────────────
# Opcional — si se configura, los agentes envían alertas al chat indicado
# Crear bot en: https://t.me/BotFather → /newbot → copiar token
# TELEGRAM_CHAT_ID: tu ID de usuario o ID del grupo (usar @userinfobot para obtenerlo)
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_CHAT_ID=CHANGE_ME

# Token compartido entre el super-agent y el backend para consultas internas.
# Genera uno seguro: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SUPER_AGENT_TOKEN=CHANGE_ME

# URL interna del backend (usada por el super-agent para consultas internas).
# En producción: http://localhost:3020 (mismo servidor)
BACKEND_URL=http://localhost:3020

# UUID de la organización principal del servidor (para consultas del bot de Telegram).
# Obtener con: SELECT id FROM organizations LIMIT 1;
PRIMARY_ORG_ID=CHANGE_ME

# ── Soporte ────────────────────────────────────────────────────
# Email de soporte visible en /upgrade y otras páginas públicas
NEXT_PUBLIC_SUPPORT_EMAIL=soporte@CHANGE_ME.com

# ── Analytics (opcional) ───────────────────────────────────────
# NEXT_PUBLIC_ANALYTICS_URL=https://CHANGE_ME.com/api/v1/analytics
